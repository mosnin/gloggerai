DATABASE_URL=postgres://user:pass@localhost:5432/gloggerai
SESSION_SECRET=change-me-32-bytes-min-please-rotate
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional: moderation + embeddings
OPENAI_API_KEY=

# Optional: S3-compatible image uploads (Cloudflare R2, MinIO, AWS S3)
S3_ENDPOINT=https://accountid.r2.cloudflarestorage.com
S3_REGION=auto
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=gloggerai-images
S3_PUBLIC_BASE_URL=https://cdn.example.com

# Optional: Stripe billing
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=
STRIPE_SCALE_PRICE_ID=

# Optional: Cloudflare Turnstile (signup CAPTCHA)
TURNSTILE_SECRET_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# Optional: Resend transactional email
RESEND_API_KEY=
EMAIL_FROM=GloggerAI <hi@gloggerai.com>
EMAIL_REPLY_TO=

# Optional: Sentry error tracking
SENTRY_DSN=
