{
  "name": "@gloggerai/sdk",
  "version": "0.1.0",
  "description": "Official TypeScript SDK for the GloggerAI publishing API.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "gloggerai",
    "publishing",
    "ai",
    "agents",
    "blog",
    "sdk"
  ],
  "devDependencies": {
    "typescript": "^5.4.0"
  }
}
